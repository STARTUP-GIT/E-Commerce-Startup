# ============================================================
# Environment Configuration Example
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Database (required)
# Local: postgresql://postgres:postgres@localhost:5432/marketplace?schema=public
# Render: Set via Render Dashboard Environment Variables
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace?schema=public

# Node Environment
NODE_ENV=development

# Session / JWT
CUSTOMER_SESSION_SECRET=change-me-to-a-random-secret
JWT_SECRET_KEY=change-me-to-a-random-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Payment Gateway (RAZORPAY or PHONEPE)
PAYMENT_GATEWAY=RAZORPAY
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# PhonePe (if PAYMENT_GATEWAY=PHONEPE)
PHONEPE_MERCHANT_ID=your-merchant-id
PHONEPE_SALT_KEY=your-salt-key
PHONEPE_SALT_INDEX=1
PHONEPE_HOST_URL=https://api-preprod.phonepe.com/apis/hermes

# Payment Callback URLs (override in production)
PAYMENT_CALLBACK_URL=https://e-commerce-startup-customer.onrender.com/payment-callback
PAYMENT_REFUND_CALLBACK_URL=https://e-commerce-startup-customer.onrender.com/refund-callback

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=your-email@example.com
APP_NAME=E-Commerce Startup

# Frontend URLs
CUSTOMER_FRONTEND_URL=https://e-commerce-startup-customer.onrender.com
SELLER_FRONTEND_URL=https://e-commerce-startup-seller.onrender.com
ADMIN_FRONTEND_URL=https://e-commerce-startup-admin.onrender.com

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_URL=cloudinary://key:secret@cloud-name

# AWS S3 (alternative file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# Delivery Provider
DELIVERY_PROVIDER=PORTER
PORTER_API_KEY=
PORTER_API_URL=https://api.porter.in
PORTER_WEBHOOK_SECRET=
