// =============================================================================
// AdminAction — immutable audit log of all admin operations
// =============================================================================

model AdminAction {
  id            String          @id @default(cuid())
  adminId       String
  actionType    AdminActionType
  targetType    String          @db.VarChar(50)
  targetId      String          @db.VarChar(30)
  description   String          @db.Text
  previousValue Json?
  newValue      Json?
  ipAddress     String?         @db.VarChar(45)
  userAgent     String?         @db.VarChar(512)
  performedAt   DateTime        @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Restrict)

  @@index([adminId])
  @@index([actionType])
  @@index([targetType, targetId])
  @@index([performedAt])
  @@index([adminId, performedAt])
  @@map("admin_actions")
}
