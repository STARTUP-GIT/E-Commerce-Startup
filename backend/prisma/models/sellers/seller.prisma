// =============================================================================
// Seller — completely independent entity with shop, products, and verification
// =============================================================================

model Seller {
  id                String       @id @default(cuid())
  username          String       @unique
  email             String       @unique @db.VarChar(320)
  passwordHash      String?      @db.VarChar(255)
  googleId          String?      @unique @db.VarChar(255)
  authProvider      AuthProvider @default(EMAIL)
  firstName         String       @db.VarChar(100)
  lastName          String       @db.VarChar(100)
  phone             String?      @db.VarChar(20)
  avatarUrl         String?      @db.VarChar(2048)
  status            SellerStatus @default(ACTIVE)
  isBanned          Boolean      @default(false)
  bannedAt          DateTime?
  banReason         String?      @db.Text
  approvedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?      @db.Text
  approvedByAdminId String?      @db.VarChar(30)
  emailVerified     Boolean      @default(false)
  lastLoginAt       DateTime?
  strikeCount       Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  isDeactivated     Boolean      @default(false)
  deactivatedAt     DateTime?
  scheduledDeleteAt DateTime?

  shop              Shop?
  addresses         SellerAddress[]
  bankAccounts      SellerBankAccount[]
  products          Product[]
  sellerOrders      SellerOrder[]
  verifications     SellerVerification[]
  strikes           SellerStrike[]
  customOrderQuotes CustomOrderQuote[]
  packingProofs     PackingProof[]
  returnRequests    ReturnRequest[]
  payouts           SellerPayout[]
  dailyMetrics      SellerDailyMetric[]
  inventoryLogs     InventoryLog[]
  approvedByAdmin   Admin?               @relation("SellerApprovedBy", fields: [approvedByAdminId], references: [id], onDelete: SetNull)
  notifications     Notification[]
  refreshTokens     SellerRefreshToken[]
  supportTickets    SupportTicket[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([isBanned])
  @@index([createdAt])
  @@index([approvedByAdminId])
  @@map("sellers")
}

model Shop {
  id                     String     @id @default(cuid())
  sellerId               String     @unique
  name                   String     @db.VarChar(200)
  slug                   String     @unique @db.VarChar(220)
  description            String?    @db.Text
  logoUrl                String?    @db.VarChar(2048)
  bannerUrl              String?    @db.VarChar(2048)
  businessName           String?    @db.VarChar(200)
  gstNumber              String?    @db.VarChar(15)
  gstRegistered          Boolean    @default(true)
  supportEmail           String?    @db.VarChar(320)
  supportPhone           String?    @db.VarChar(20)
  defaultPickupAddressId String?
  status                 ShopStatus @default(PENDING)
  rejectionReason        String?    @db.Text
  reviewedByAdminId      String?    @db.VarChar(30)
  reviewedAt             DateTime?
  enablePackingFee       Boolean    @default(false)
  packingFeeApproved     Boolean    @default(false)
  commissionPercentage   Float      @default(10.0)
  customerDeliveryShare  Int        @default(75)
  sellerDeliveryShare    Int        @default(25)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  seller               Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  defaultPickupAddress SellerAddress? @relation("ShopDefaultPickupAddress", fields: [defaultPickupAddressId], references: [id], onDelete: SetNull)
  reviewedByAdmin      Admin?         @relation("ShopReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([status])
  @@index([defaultPickupAddressId])
  @@map("shops")
}

model ProductReport {
  id                String              @id @default(cuid())
  productId         String
  customerId        String
  reason            String              @db.Text
  description       String?             @db.Text
  status            ProductReportStatus @default(PENDING)
  reviewedByAdminId String?             @db.VarChar(30)
  reviewedAt        DateTime?
  resolution        String?             @db.Text
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reviewedByAdmin Admin?   @relation("ProductReportReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("product_reports")
}
