// =============================================================================
// SellerDailyMetric — pre-aggregated sales analytics for seller dashboard
// =============================================================================

model SellerDailyMetric {
  id                String   @id @default(cuid())
  sellerId          String
  date              DateTime @db.Date
  totalOrders       Int      @default(0)
  totalRevenue      Decimal  @default(0) @db.Decimal(14, 2)
  totalUnitsSold    Int      @default(0)
  totalReturns      Int      @default(0)
  totalRefunds      Decimal  @default(0) @db.Decimal(14, 2)
  averageOrderValue Decimal  @default(0) @db.Decimal(12, 2)
  newCustomers      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, date])
  @@index([sellerId])
  @@index([date])
  @@index([sellerId, date])
  @@map("seller_daily_metrics")
}
