model DeliveryMethodSetting {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  description  String?
  enabled      Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("delivery_methods")
}
