// =============================================================================
// CustomOrderQuote — seller quotes for custom manufacturing jobs
// =============================================================================

model CustomOrderQuote {
  id              String    @id @default(cuid())
  customOrderId   String
  sellerId        String
  quotedPrice     Decimal   @db.Decimal(12, 2)
  currency        String    @default("INR") @db.VarChar(3)
  estimatedDays   Int
  notes           String?   @db.Text
  validUntil      DateTime
  isAccepted      Boolean   @default(false)
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customOrder     CustomOrder  @relation(fields: [customOrderId], references: [id], onDelete: Cascade)
  seller          Seller       @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  acceptedByOrder CustomOrder? @relation("AcceptedQuote")

  @@unique([customOrderId, sellerId])
  @@index([customOrderId])
  @@index([sellerId])
  @@index([validUntil])
  @@index([isAccepted])
  @@map("custom_order_quotes")
}
