// =============================================================================
// City — marketplace coverage management; enable/disable operation regions
// =============================================================================

model City {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(100)
  state     String   @default("Karnataka") @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([isActive])
  @@map("cities")
}
