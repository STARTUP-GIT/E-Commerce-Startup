// =============================================================================
// Payment — customer financial transactions (isolated from seller entity)
// =============================================================================

model Payment {
  id               String        @id @default(cuid())
  orderId          String
  customerId       String
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("INR") @db.VarChar(3)
  status           PaymentStatus @default(PENDING)
  method           PaymentMethod
  gatewayPaymentId String?       @unique @db.VarChar(255)
  gatewayOrderId   String?       @db.VarChar(255)
  gatewaySignature String?       @db.VarChar(512)
  packingFee       Decimal       @default(0) @db.Decimal(12, 2)
  shippingCharge   Decimal       @default(0) @db.Decimal(12, 2)
  gstPercentage    Decimal       @default(0) @db.Decimal(5, 2)
  gstAmount        Decimal       @default(0) @db.Decimal(12, 2)
  platformFee      Decimal?      @db.Decimal(12, 2)
  invoiceNumber    String?       @db.VarChar(50)
  failureReason    String?       @db.Text
  refundAmount     Decimal       @default(0) @db.Decimal(12, 2)
  paidAt           DateTime?
  refundedAt       DateTime?
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  order          Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  customer       Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  timelineEvents OrderTimelineEvent[]

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([gatewayPaymentId])
  @@index([createdAt])
  @@index([customerId, status])
  @@map("payments")
}
