// =============================================================================
// PlatformDailyMetric — admin platform-wide analytics aggregates
// =============================================================================

model PlatformDailyMetric {
  id              String   @id @default(cuid())
  date            DateTime @unique @db.Date
  totalOrders     Int      @default(0)
  totalRevenue    Decimal  @default(0) @db.Decimal(16, 2)
  totalCommission Decimal  @default(0) @db.Decimal(16, 2)
  activeCustomers Int      @default(0)
  activeSellers   Int      @default(0)
  newCustomers    Int      @default(0)
  newSellers      Int      @default(0)
  totalReturns    Int      @default(0)
  totalDeliveries Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@map("platform_daily_metrics")
}
