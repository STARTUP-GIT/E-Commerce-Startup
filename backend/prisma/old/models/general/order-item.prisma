// =============================================================================
// OrderItem — immutable snapshot of product at time of purchase
// =============================================================================

model OrderItem {
  id               String   @id @default(cuid())
  sellerOrderId    String
  productId        String
  productVariantId String?
  productName      String   @db.VarChar(300)
  productSku       String   @db.VarChar(100)
  variantName      String?  @db.VarChar(200)
  productImage     String?  @db.VarChar(2048)
  quantity         Int
  unitPrice        Decimal  @db.Decimal(12, 2)
  totalPrice       Decimal  @db.Decimal(12, 2)
  taxAmount        Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sellerOrder    SellerOrder     @relation(fields: [sellerOrderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  review         Review?
  returnRequest  ReturnRequest?

  @@index([sellerOrderId])
  @@index([productId])
  @@index([productVariantId])
  @@map("order_items")
}
