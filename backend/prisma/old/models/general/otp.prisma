// =============================================================================
// Otp — OTP-based password recovery and verification (entity-agnostic)
// =============================================================================

model Otp {
  id          String        @id @default(cuid())
  entityType  OtpEntityType
  entityId    String        @db.VarChar(30)
  email       String        @db.VarChar(320)
  codeHash    String        @db.VarChar(255)
  purpose     OtpPurpose
  attempts    Int           @default(0)
  maxAttempts Int           @default(5)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime      @default(now())

  @@index([email, purpose])
  @@index([entityType, entityId, purpose])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("otps")
}
