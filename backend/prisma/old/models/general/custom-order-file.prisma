// =============================================================================
// CustomOrderFile — uploaded CAD files (STL, STEP, OBJ)
// =============================================================================

model CustomOrderFile {
  id            String         @id @default(cuid())
  customOrderId String
  fileName      String         @db.VarChar(300)
  fileUrl       String         @db.VarChar(2048)
  fileType      CustomFileType
  fileSizeBytes BigInt
  mimeType      String?        @db.VarChar(100)
  uploadedAt    DateTime       @default(now())

  customOrder CustomOrder @relation(fields: [customOrderId], references: [id], onDelete: Cascade)

  @@index([customOrderId])
  @@index([fileType])
  @@map("custom_order_files")
}
